# Google Gemini API (free tier) - get key at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-google-api-key

# Groq API (free tier) - get key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key

# Supabase (free tier) - get from Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Tavily Search API (free tier: 1000 req/month) - get at https://tavily.com
TAVILY_API_KEY=tvly-dev-your-key

# Optional
PORT=3001
CORS_ORIGIN=*
